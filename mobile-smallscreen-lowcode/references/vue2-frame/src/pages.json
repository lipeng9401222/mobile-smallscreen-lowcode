// 为了防止多人协作时出现冲突，在v8.3.10版本之后，pages.json不再生成路由pages和分包路由subPackages的信息。路由配置仍然由各模块下的router.js文件中的配置以生效。
// 其他pages.json下的配置仍然在此处生效。
// 完整的pages.json信息在构建过程中会同步到node_modules/@epoint-mrc/.cache/${UNI_PLATFORM}/pages.router.json中，如果需要可以查看该文件。
{
    "globalStyle": {
        "navigationBarTextStyle": "black",
        "navigationBarTitleText": "",
        "backgroundColor": "#F8F8F8",
        "mp-weixin": {
            "navigationBarBackgroundColor": "#F8F8F8"
        }
    },
    "easycom": {
        "autoscan": true,
        "custom": {
            "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue",
            "^em-(chart|table-col|table|pagination)": "@epoint-mrc/em-components/src/sub_components/em-$1/em-$1.vue",
            "^em-(.*)": "@epoint-mrc/em-components/src/components/em-$1/em-$1.vue"
        }
    },
    "insetLoader": {
        "config": {
            "ejsApi": "<em-ejs-api ref='emEjsApi'></em-ejs-api>"
        },
        "label": [
            "ejsApi"
        ],
        "rootEle": ".*"
    }
}