        "@epoint-mfe/eui-icons": "8.4.5-beta.4",
        "@epoint-mrc/ejsv4": "4.2.22",
        "@epoint-mrc/em-components": "8.4.5-beta.26",
        "@epoint-mrc/rtc": "0.0.13",
        "@epoint-mrc/utils": "8.4.5-beta.26",
        "@epoint-mrc/vite-plugin-mc": "8.4.5-beta.26",
