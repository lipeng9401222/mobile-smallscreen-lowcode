        "eslint-plugin-vue": "^9.19.2",
        "postcss": "^8.4.32",
        "postcss-html": "^1.5.0",
        "postcss-scss": "^4.0.9",
        "prettier": "^3.2.5",
        "sass": "1.71.1",
