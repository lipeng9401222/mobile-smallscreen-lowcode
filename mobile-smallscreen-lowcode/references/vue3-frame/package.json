{
    "name": "ejs.m8.mobileframe",
    "version": "8.4.5-beta.26",
    "scripts": {
        "dev": "npm run dev:h5",
        "dev:app": "uni -p app",
        "dev:app-android": "uni -p app-android",
        "dev:app-ios": "uni -p app-ios",
        "dev:custom": "uni -p",
        "dev:h5": "cross-env NODE_ENV=development UNI_PLATFORM=h5 pre-env uni -- ",
        "dev:h5:ssr": "uni --ssr",
        "dev:mp-alipay": "cross-env NODE_ENV=development UNI_PLATFORM=mp-alipay pre-env uni -p mp-alipay --",
        "dev:mp-weixin": "cross-env NODE_ENV=development UNI_PLATFORM=mp-weixin pre-env uni -p mp-weixin --",
        "dev:mp-epoint": "cross-env NODE_ENV=development UNI_PLATFORM=mp-epoint pre-env uni -p mp-epoint --",
        "build": "npm run build:h5",
        "build:app": "uni build -p app",
        "build:app-android": "uni build -p app-android",
        "build:app-ios": "uni build -p app-ios",
        "build:custom": "uni build -p",
        "build:h5": "cross-env NODE_ENV=production UNI_PLATFORM=h5 NODE_OPTIONS=--max-old-space-size=4096 pre-env uni build --",
        "build:h5:ssr": "uni build --ssr",
        "build:mp-alipay": "cross-env NODE_ENV=production UNI_PLATFORM=mp-alipay pre-env uni build -p mp-alipay --",
        "build:mp-weixin": "cross-env NODE_ENV=production UNI_PLATFORM=mp-weixin pre-env uni build -p mp-weixin --",
        "build:mp-epoint": "cross-env NODE_ENV=production UNI_PLATFORM=mp-epoint pre-env uni build -p mp-epoint --",
        "type-check": "vue-tsc --noEmit",
        "multiple:all": "node node_modules/@epoint-mrc/em-cli/src/lib/resolution/multiple/allscript.js",
        "build:common": "mrc-mccommon",
        "ioc": "cross-env UNI_PLATFORM=h5 pre-env epoint-mc",
        "lint": "eslint ."
    },
    "dependencies": {
        "@dcloudio/uni-app": "3.0.0-4070620250821001",
        "@dcloudio/uni-app-plus": "3.0.0-4070620250821001",
