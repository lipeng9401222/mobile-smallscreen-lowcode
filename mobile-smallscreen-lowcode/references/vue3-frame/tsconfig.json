{
    "compilerOptions": {
        "target": "es2017",
        "composite": true,
        "skipLibCheck": true,
        "module": "NodeNext",
        "moduleResolution": "nodenext",
        "customConditions": ["mobile"],
        "allowSyntheticDefaultImports": true,
        "sourceMap": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@boot": [
                "./src/shared/boot"
            ],
            "@store": [
                "./src/store"
            ],
            "@mock": [
                "./node_modules/better-mock-del-gyp/dist/mock.mp"
            ],
            "@components/*": [
                "./node_modules/@epoint-mrc/em-components/src/components/*"
            ]
        },
        "outDir": "dist",
        "lib": [
            "esnext",
            "dom"
        ],
        "types": [
            "@types/node",
            "@epoint-mrc/types",
            "@dcloudio/types",
            "@types/wechat-miniprogram",
            "@epoint-mrc/ejsv4"
        ],
        "allowJs": true
    },
    "vueCompilerOptions": {
        "nativeTags": [
            "block",
            "template",
            "component",
            "slot"
        ]
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.js",
        "src/**/*.d.ts",
        "src/**/*.tsx",
        "src/**/*.vue",
        "src/**/*.json",
        "custom/**/*.ts",
        "custom/**/*.js",
        "custom/**/*.d.ts",
        "custom/**/*.tsx",
        "custom/**/*.vue",
        "custom/**/*.json"
    ]
}